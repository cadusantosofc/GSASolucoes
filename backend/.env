// Configurações do Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/consulta?schema=public"

// Segurança
JWT_SECRET="GSA_ULTRA_SECURE_SECRET_$(openssl rand -base64 32 2>nul || echo 'fallback_secret_123')"
JWT_EXPIRES_IN="7d"

// Porta do Servidor
PORT=3001

BACKEND_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"